{
  "description": "Commands and patterns explicitly denied by CrocAgentic policy.",
  "version": "1.1.0",
  "commands": [
    "rm",
    "rmdir",
    "sudo",
    "su",
    "chmod",
    "chown",
    "chgrp",
    "dd",
    "mkfs",
    "fdisk",
    "parted",
    "shutdown",
    "reboot",
    "halt",
    "poweroff",
    "init",
    "systemctl",
    "service",
    "kill",
    "killall",
    "pkill",
    "iptables",
    "ufw",
    "nc",
    "netcat",
    "nmap",
    "tcpdump",
    "wireshark",
    "ssh-keygen",
    "passwd",
    "useradd",
    "userdel",
    "groupadd",
    "visudo",
    "crontab",
    "at",
    "screen",
    "nohup",
    "disown"
  ],
  "dangerousPatterns": [
    "curl .* \\| .*bash",
    "curl .* \\| .*sh",
    "wget .* \\| .*bash",
    "wget .* \\| .*sh",
    "base64 -d .* \\|",
    "eval .*\\$\\(",
    "exec .*\\$\\(",
    "xargs.*rm",
    "find.*-delete",
    "find.*-exec.*rm",
    "/etc/passwd",
    "/etc/shadow",
    "/etc/sudoers"
  ]
}
