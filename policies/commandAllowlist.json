{
  "version": "1.3.0",
  "description": "Commands the agent is permitted to execute",
  "allowedCommands": [
    "ls", "ll", "la", "dir",
    "cat", "type", "more", "less", "head", "tail",
    "echo", "print", "printf",
    "pwd", "cd",
    "mkdir", "touch", "cp", "mv",
    "find", "grep", "search",
    "wc", "sort", "uniq", "diff", "sed", "awk",
    "date", "whoami", "hostname", "uname", "id",
    "git", "git-log",
    "npm", "npx", "yarn", "pnpm",
    "node", "ts-node", "tsx",
    "python", "python3", "pip", "pip3",
    "sh", "bash", "zsh",
    "curl", "wget",
    "tar", "zip", "unzip", "gzip",
    "ps", "top", "df", "du", "free", "uptime",
    "env", "set", "export",
    "which", "where", "type",
    "test", "true", "false",
    "tee", "xargs", "read"
  ],
  "notes": [
    "sh/bash/zsh allowed for script execution",
    "Destructive commands (rm, sudo, format) are on the DENYLIST",
    "Network commands (curl/wget) allowed but URLs checked against networkAllowlist.json"
  ]
}
