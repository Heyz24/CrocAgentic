# CrocAgentic Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── LLM API Keys (bring your own) ──────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ─── Connectors (all optional) ──────────────────────────────────────────────

# Email (Gmail: use App Password from myaccount.google.com/apppasswords)
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_CHECK_INTERVAL_MS=30000

# Telegram Bot (create at t.me/BotFather)
# TELEGRAM_BOT_TOKEN=
# ESCALATION_TELEGRAM_CHAT_ID=

# Slack
# SLACK_BOT_TOKEN=
# ESCALATION_SLACK_CHANNEL=#general

# WhatsApp (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=+14155238886

# WhatsApp (Meta Cloud API)
# META_WHATSAPP_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=

# GitHub
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo

# Notion
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# Google Drive
# GOOGLE_DRIVE_API_KEY=

# ─── Search ──────────────────────────────────────────────────────────────────
# Optional: Tavily for better web search (free tier: 1000/month)
# TAVILY_API_KEY=

# ─── Advanced ────────────────────────────────────────────────────────────────
# PORT=3000
# LOG_LEVEL=info
# LLM_CALLS_PER_MIN=15
# FILE_WATCHER=true
# WATCH_DIR=runtime/inbox
# OUTPUT_DIR=runtime/inbox_output
# SERVER_URL=http://localhost:3000
